.page {
  padding: 28rpx 28rpx 60rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 区块 */
.section {
  margin-bottom: 10rpx;
}
.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #3d3226;
  display: block;
  margin-bottom: 12rpx;
}
.section-hint {
  font-size: 22rpx;
  color: #b8a99a;
  display: block;
  margin-bottom: 20rpx;
}

/* 表单行 */
.form-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #ede4d6;
}
.form-label {
  font-size: 28rpx;
  color: #3d3226;
}
.picker-val {
  font-size: 28rpx;
  color: #8b7355;
}

/* 性别 */
.gender-row {
  display: flex;
  gap: 20rpx;
}
.gender-btn {
  width: 88rpx;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  font-size: 26rpx;
  color: #8b7355;
  border: 1rpx solid #d4c5b0;
  border-radius: 28rpx;
}
.gender-btn.active {
  background: #8b7355;
  color: #fff;
  border-color: #8b7355;
}

/* 分割线 */
.divider-wrap {
  padding: 20rpx 0;
}
.divider {
  height: 1rpx;
  background: #e8dccf;
}

/* 问卷折叠 */
.quiz-toggle {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
}
.toggle-arrow {
  font-size: 32rpx;
  color: #b8a99a;
}

/* 问卷 */
.group-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
  margin-top: 24rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #5a4a3a;
}
.group-status {
  font-size: 22rpx;
  font-weight: 400;
}
.status-high { color: #c67b5c; }
.status-mid  { color: #b8a050; }
.status-low  { color: #b8a99a; }

.question {
  padding: 16rpx 0 8rpx;
  border-bottom: 1rpx solid #f5efe4;
}
.q-text {
  font-size: 26rpx;
  color: #3d3226;
  line-height: 1.6;
}
.slider-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 8rpx;
}
.slider-row slider {
  flex: 1;
}
.slider-val {
  font-size: 24rpx;
  color: #8b7355;
  width: 32rpx;
  text-align: center;
}

/* 保存 */
.save-btn {
  margin-top: 40rpx;
  background: #8b7355;
  color: #fff;
  font-size: 28rpx;
  border-radius: 40rpx;
  border: none;
  padding: 16rpx 0;
}
.saved-msg {
  display: block;
  text-align: center;
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #7a9a6a;
}

.location-status {
  font-size: 20rpx;
  color: #b8a99a;
  display: block;
  margin-top: 8rpx;
}
.location-status.ok {
  color: #7a9a6a;
}
